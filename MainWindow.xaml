<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        xmlns:easy="clr-namespace:EasyCaptcha.Wpf;assembly=EasyCaptcha.Wpf"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="MainWindow" Height="400" Width="350">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Content="Label" HorizontalAlignment="Left" Margin="25,43,0,0" VerticalAlignment="Top" Width="330" Height="26"/>
        <TextBox x:Name="Login" Margin="0,74,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="300" Height="30"/>
        <Label Content="Label" HorizontalAlignment="Left" Margin="25,114,0,0" VerticalAlignment="Top" Height="26" Width="38"/>
        <TextBox x:Name="Password" Margin="0,140,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="300" Height="30"/>
        <Label Content="Label" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Height="26" Width="38"/>
        <easy:Captcha x:Name="Capcha" Margin="75,175,75,83"/>
        <TextBox x:Name="CapchaInput" HorizontalAlignment="Center" Margin="0,247,0,48" TextWrapping="Wrap" Text="TextBox" Width="300" Height="30"/>
        <StackPanel Height="30" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <Button Content="Button1" HorizontalAlignment="Left"  Width="100" Click="ReGenerateCapcha" Height="30"/>
            <Button Content="Button2" HorizontalAlignment="Left"  Height="30" Width="100" Click="LoginButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
