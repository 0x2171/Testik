<Window x:Class="WpfApp1.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Main" Height="450" Width="800">
    <DockPanel>
        <Menu x:Name="Menu" DockPanel.Dock="Left" Width="160" HorizontalAlignment="Left">
            <MenuItem Header="Меню" FontSize="14"></MenuItem>
            <MenuItem Header="Редактировать" FontSize="14"></MenuItem>
            <MenuItem Header="Показать" FontSize="14"></MenuItem>
            <MenuItem Header="Администратирование" FontSize="14"></MenuItem>
        </Menu>
    </DockPanel>
</Window>
